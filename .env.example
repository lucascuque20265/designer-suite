# Exemplo de variáveis de ambiente usadas pelo projeto
# Copie para `.env` localmente e preencha com seus valores.

# Client-side (vite) - prefixe VITE_ para serem embutidas no bundle cliente
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Server-side (SSR / funções) - não exponha estas chaves no navegador
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
